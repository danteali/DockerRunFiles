#!/bin/bash

NAME="ha-dockermon"

docker rm -f -v $NAME

docker run -d \
  --name=$NAME \
  --restart="unless-stopped" \
  -l org.label-schema.group="monitoring" \
  -p 8126:8126 \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v /storage/Docker/$NAME/config:/config \
  philhawthorne/ha-dockermon

# Start container
docker start $NAME

