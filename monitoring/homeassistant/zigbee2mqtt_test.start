#!/bin/bash

# Get sensitive info from .conf file
CONF_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
typeset -A secrets    # Define array to hold variables 
while read line; do
  if echo $line | grep -F = &>/dev/null; then
    varname=$(echo "$line" | cut -d '=' -f 1); secrets[$varname]=$(echo "$line" | cut -d '=' -f 2-)
  fi
done < $CONF_DIR/zigbee2mqtt.conf
#echo ${secrets[FQDN]}; echo ${secrets[IP]}

FQDN="${secrets[FQDN]}"
NAME="zigbee2mqtt_test"

docker rm -f -v $NAME

docker create \
  --name=$NAME \
  --restart="unless-stopped" \
  -p 11122:11121 \
  `#--net=host` \
  -l org.label-schema.group="monitoring" \
  -v /storage/Docker/zigbee2mqtt_test/data:/app/data \
  `#-v /storage/Docker/zigbee2mqtt_test/data/zigbee-shepherd-converters:/app/node_modules/zigbee-shepherd-converters` \
  `#-v /storage/Docker/zigbee2mqtt_test/data/lib/extension/homeassistant.js:/app/lib/extension/homeassistant.js` \
  --device=/dev/ttyUSB0 \
  --log-driver json-file \
  --log-opt max-size=20m \
  --log-opt max-file=10 \
  `# ------- Traefik Proxy Section -------` \
  -l "traefik.enable=true" \
  -l "traefik.port=11122" \
  -l "traefik.frontend.rule=Host:test_zigbee2mqtt.$FQDN" \
  `# -------------------------------------` \
  koenkk/zigbee2mqtt:latest-dev
  #koenkk/zigbee2mqtt:1.16.2
  #koenkk/zigbee2mqtt:1.14.2
  #koenkk/zigbee2mqtt:1.4.0


# Add to traefik-proxy network so it can reach the other container
docker network connect bridge $NAME
docker network connect traefik-proxy $NAME

# Start container
docker start $NAME
